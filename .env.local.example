# Copier ce fichier en .env.local puis remplir les valeurs depuis le dashboard Supabase
# Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ⚠️ CLÉ SERVICE ROLE — REQUISE pour le panneau /superadmin (bypass RLS)
# À récupérer dans Supabase Dashboard > Settings > API > service_role key
# NE JAMAIS exposer côté client ni commiter dans Git
SUPABASE_SERVICE_ROLE_KEY=

# Super admin SaaS (panneau /superadmin)
# Mot de passe maître (6 caractères minimum)
SUPERADMIN_PASSWORD=changez-moi-en-prod
# Secret pour signer les cookies (32+ caractères aléatoires recommandés)
SUPERADMIN_SECRET=remplacez-par-une-chaine-aleatoire-de-32-caracteres-minimum
