# ============================================================================
# Supabase — Project Settings > API
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ⚠️ CLÉ SERVICE ROLE — REQUISE pour /superadmin et invitation d'équipe
# Settings > API > service_role key (cliquer "Reveal")
# NE JAMAIS exposer côté client ni commiter dans Git
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Super admin SaaS (panneau /superadmin)
# ============================================================================
SUPERADMIN_PASSWORD=changez-moi-en-prod
SUPERADMIN_SECRET=remplacez-par-une-chaine-aleatoire-de-32-caracteres-minimum

# ============================================================================
# Resend — emails transactionnels (https://resend.com)
# ============================================================================
# 1. Inscrivez-vous sur resend.com (gratuit jusqu'à 3000 emails/mois)
# 2. Récupérez votre clé API : https://resend.com/api-keys
# 3. (Production) Vérifiez un domaine : https://resend.com/domains
RESEND_API_KEY=re_xxxxxxxxxxxx

# Adresse expéditeur (format "Nom <email@domaine.com>")
# - En DEV : laissez "GestHotel <onboarding@resend.dev>" (par défaut)
# - En PROD : utilisez votre domaine vérifié, ex : "GestHotel <no-reply@gesthotel.app>"
RESEND_FROM=GestHotel <onboarding@resend.dev>

# Email où recevoir les notifications administrateur (contact form, nouvelles inscriptions)
RESEND_ADMIN_EMAIL=danielzehima@gmail.com

# ============================================================================
# GeniusPay — paiements d'abonnement (https://pay.genius.ci/docs/api)
# ============================================================================
# Récupérez vos clés dans votre tableau de bord GeniusPay (section API / Développeur).
# ⚠️ COMMENCEZ EN SANDBOX (clés pk_sandbox_ / sk_sandbox_) avant de passer en live.
# Le secret (X-API-Secret) et le webhook secret restent SERVEUR — ne jamais les exposer côté client.
GENIUSPAY_API_KEY=pk_sandbox_xxxxxxxx
GENIUSPAY_API_SECRET=sk_sandbox_xxxxxxxx
GENIUSPAY_WEBHOOK_SECRET=whsec_xxxxxxxx
# (optionnel) override de l'URL d'API — défaut https://pay.genius.ci/api/v1
# GENIUSPAY_BASE_URL=https://pay.genius.ci/api/v1

# URL publique de l'app (sert à construire l'URL de retour après paiement)
# DEV : http://localhost:3000 — PROD : https://votre-domaine
NEXT_PUBLIC_APP_URL=https://gestb-hotel.vercel.app

# ⚠️ Dans le tableau de bord GeniusPay, configurez l'URL de webhook sur :
#    https://votre-domaine/api/webhooks/geniuspay

# ============================================================================
# Cron — relances d'expiration de forfait (Vercel Cron)
# ============================================================================
# Chaîne aléatoire. Vercel l'ajoute automatiquement en header Authorization
# lors de l'appel du cron défini dans vercel.json (/api/cron/expiry-reminders).
# À définir AUSSI dans les variables d'environnement Vercel.
CRON_SECRET=remplacez-par-une-chaine-aleatoire
