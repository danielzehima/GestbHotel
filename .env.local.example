# ============================================================================
# Supabase — Project Settings > API
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ⚠️ CLÉ SERVICE ROLE — REQUISE pour /superadmin et invitation d'équipe
# Settings > API > service_role key (cliquer "Reveal")
# NE JAMAIS exposer côté client ni commiter dans Git
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Super admin SaaS (panneau /superadmin)
# ============================================================================
SUPERADMIN_PASSWORD=changez-moi-en-prod
SUPERADMIN_SECRET=remplacez-par-une-chaine-aleatoire-de-32-caracteres-minimum

# ============================================================================
# Resend — emails transactionnels (https://resend.com)
# ============================================================================
# 1. Inscrivez-vous sur resend.com (gratuit jusqu'à 3000 emails/mois)
# 2. Récupérez votre clé API : https://resend.com/api-keys
# 3. (Production) Vérifiez un domaine : https://resend.com/domains
RESEND_API_KEY=re_xxxxxxxxxxxx

# Adresse expéditeur (format "Nom <email@domaine.com>")
# - En DEV : laissez "GestHotel <onboarding@resend.dev>" (par défaut)
# - En PROD : utilisez votre domaine vérifié, ex : "GestHotel <no-reply@gesthotel.app>"
RESEND_FROM=GestHotel <onboarding@resend.dev>

# Email où recevoir les notifications administrateur (contact form, nouvelles inscriptions)
RESEND_ADMIN_EMAIL=danielzehima@gmail.com
